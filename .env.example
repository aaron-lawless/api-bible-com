# Injected automatically by Railway per environment - do not set manually on Railway
DATABASE_URL=postgresql://user:pass@host.railway.internal:5432/railway

# Local dev only: public proxy URL for nprd or production Postgres
LOCAL_DATABASE_URL=postgresql://user:pass@switchyard.proxy.rlwy.net:PORT/railway

OPENAI_API_KEY=sk-...
OPENAI_TIMEOUT_SECONDS=120
EMBEDDING_BATCH_SIZE=5

MAX_CONTENT_LENGTH=52428800
FLASK_ENV=development
SECRET_KEY=change-me
ADMIN_PASSWORD=change-me
